DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

# Django authentication service
NEXT_PUBLIC_DJANGO_URL=http://localhost:8000
DJANGO_INTERNAL_URL=http://127.0.0.1:8000
NEXT_APP_ORIGIN=http://localhost:5000
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5000
DJANGO_SECURE_COOKIES=0
DJANGO_SSL_REDIRECT=0
DJANGO_HSTS_SECONDS=0

# FastAPI business service. Next.js only reaches it server-to-server.
ECCP_API_INTERNAL_URL=http://127.0.0.1:8100
ECCP_INTERNAL_AUTH_SECRET=replace-with-a-long-random-secret
ECCP_API_INTERNAL_AUTH_SECRET=replace-with-the-same-long-random-secret

# Local zero-dependency development defaults. Production uses Compose values below.
ECCP_API_DATABASE_URL=sqlite+aiosqlite:///./backend/eccp_api.db
ECCP_API_REDIS_URL=
ECCP_API_STORAGE_BACKEND=local
ECCP_API_STORAGE_DIR=.eccp-data/objects

# Production PostgreSQL/pgvector + Redis + S3-compatible object storage.
# ECCP_API_DATABASE_URL=postgresql+asyncpg://eccp:password@postgres:5432/eccp
# ECCP_API_REDIS_URL=redis://redis:6379/0
# ECCP_API_STORAGE_BACKEND=s3
# ECCP_API_S3_ENDPOINT_URL=http://minio:9000
# ECCP_API_S3_REGION=us-east-1
# ECCP_API_S3_ACCESS_KEY_ID=eccp
# ECCP_API_S3_SECRET_ACCESS_KEY=replace-with-secret
# ECCP_API_S3_BUCKET=eccp-documents

# Use local_hash only for local smoke tests. Production should use an embedding API.
ECCP_API_EMBEDDING_PROVIDER=local_hash
# ECCP_API_EMBEDDING_API_URL=https://your-openai-compatible-host/v1
# ECCP_API_EMBEDDING_API_KEY=
# ECCP_API_EMBEDDING_MODEL=text-embedding-3-small
